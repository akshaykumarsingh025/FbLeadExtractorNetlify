# Supabase (required - create a free project at https://supabase.com)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Facebook OAuth (required - create an app at https://developers.facebook.com)
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# Google OAuth (required - enable Sheets & Drive APIs in Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Cron job secret (optional - set this and use it with cron-job.org)
# Leave empty if not using cron-based auto-polling
CRON_SECRET=your-cron-secret

# Site URL (Netlify sets this automatically via environment variable)
# For local dev: URL=http://localhost:8888
# You don't need to set this on Netlify - it's auto-injected
URL=http://localhost:8888
